# Normalize all text files
* text=auto

# Always use LF for source files
*.c    text eol=lf
*.h    text eol=lf
*.js   text eol=lf
*.py   text eol=lf
*.sh  ol=crlf*.sh   text eol=lf
*.sln  text eol=crlf

# Binary files (never touch line endings)
*.png  binary
*.jpg  binary

# Windows-specific files
*.ps1  text eol=crlf

